# ── Core Application ───────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-production  # Generate with: openssl rand -hex 32

# ── Video Source Configuration ────────────────────────────────
VIDEO_SOURCE=0                   # 0=webcam, or rtsp://..., or /path/to/file.mp4
FRAME_SKIP=2                     # process every Nth frame (1=all, 2=every other)

# ── Model Configuration ───────────────────────────────────────
MODEL_PATH=models/best.pt
CONFIDENCE_THRESHOLD=0.45
IOU_THRESHOLD=0.45
DEVICE=cpu                       # cpu | cuda | mps

# ── Detection Classes ─────────────────────────────────────────
VIOLATION_CLASSES=no helmet,no vest   # comma-separated class names to alert on (space-separated per model output)

# ── SHAP Explainability ───────────────────────────────────────
SHAP_BACKGROUND_DIR=data/processed/train/images   # background images for SHAP baseline

# ── Backend Configuration ─────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173    # Vite dev server
API_KEY=                             # Leave empty to disable auth in development
CONTACT_EMAIL=                       # Optional: shown in Swagger UI /docs contact

# ── Database Configuration ────────────────────────────────────
# PostgreSQL (production — recommended)
DATABASE_URL=postgresql+asyncpg://safety:safety@localhost:5432/safety_monitor
# SQLite (local dev only — no postgres needed)
# DATABASE_URL=sqlite+aiosqlite:///./safety_monitor.db

# PostgreSQL pool tuning (production)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── MLflow Configuration ──────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=ppe-detection

# ── Railway Deployment (populated automatically in production) ─
PORT=8000                        # Railway injects this
RAILWAY_ENVIRONMENT=production

# ── RAG / Chatbot Configuration ───────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
CHROMA_PERSIST_DIR=./rag/chroma_db
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35

# ── Incident Reports Configuration ────────────────────────────
OPENAI_API_KEY=sk-...            # optional — GPT-4o fallback
REPORT_OUTPUT_DIR=./reports/output
REPORT_DEBOUNCE_MINUTES=480      # 8 hours (one shift)
REPORT_LLM_PRIMARY=ollama        # ollama | openai
REPORT_LLM_FALLBACK=openai       # openai | none
REPORT_MAX_QUEUE_SIZE=50         # max pending reports

# ── Drift Detection Configuration ─────────────────────────────
DRIFT_PSI_THRESHOLD=0.2
DRIFT_KS_PVALUE_THRESHOLD=0.05
DRIFT_CHECK_DAYS_BACK=1
REFERENCE_STATS_PATH=./monitoring/reference_stats.json

# ── Roboflow Integration ──────────────────────────────────────
ROBOFLOW_API_KEY=your_key_here
ROBOFLOW_WORKSPACE=your_workspace
ROBOFLOW_PROJECT=your_project
ROBOFLOW_VERSION=3

# ── Retraining Configuration ──────────────────────────────────
MLFLOW_TRACKING_URI=postgresql://user:pass@host/mlflow
NEW_MODEL_MIN_MAP_IMPROVEMENT=0.01
RETRAIN_NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/...

# ── Twilio WhatsApp Configuration ─────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number

# ── Email (SMTP) Configuration ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password          # Gmail app password, not login password
SMTP_FROM_NAME=Safety Monitor AI
SMTP_FROM_EMAIL=your_email@gmail.com

# ── Alert Throttling Configuration ────────────────────────────
ALERT_THROTTLE_MINUTES=5
ALERT_MAX_PER_HOUR=20                    # global cap per recipient
ALERT_CRITICAL_BYPASS_THROTTLE=true

# ── Proximity Detection Configuration ─────────────────────────
MACHINERY_MODEL_PATH=models/machinery_best.pt
PROXIMITY_CRITICAL_M=2.0          # metres — CRITICAL alert threshold
PROXIMITY_WARNING_M=5.0           # metres — WARNING alert threshold
PROXIMITY_DEBOUNCE_S=3.0          # seconds between same-pair alerts
CALIBRATION_DATA_PATH=./calibration/calibration_data.json
USE_PIXEL_FALLBACK=true           # use pixel distance if no calibration

# ── Fire Detection Configuration ─────────────────────────────
FIRE_MODEL_PATH=models/fire_best.pt
FIRE_CONF_THRESHOLD=0.45
SMOKE_CONF_THRESHOLD=0.40
FIRE_ALERT_BYPASS_THROTTLE=true
FIRE_HEATMAP_DECAY=0.999          # slower decay than PPE — fire lingers  

# ── LangGraph Agent Configuration ─────────────────────────────
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxx
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=safety-monitor-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Agent LLM (uses same Ollama from Phase A)
AGENT_LLM_MODEL=llama3
AGENT_SEVERITY_THRESHOLD=5        # score >= this triggers report + alert
AGENT_MAX_CONCURRENT_RUNS=3       # max parallel agent executions

# ── Multi-Camera Configuration ────────────────────────────────
MAX_CAMERAS=10
CAMERA_RECONNECT_MAX_ATTEMPTS=5
CAMERA_RECONNECT_BASE_DELAY_S=2.0
CAMERA_RECONNECT_MAX_DELAY_S=60.0
CAMERA_HEALTH_CHECK_INTERVAL_S=30
CAMERA_FRAME_QUEUE_SIZE=8
CAMERA_STATS_FLUSH_INTERVAL_S=300   # flush stats every 5 minutes

# Example RTSP cameras (add to DB via API)
# RTSP_CAM_1=rtsp://admin:password@192.168.1.100:554/stream1
# RTSP_CAM_2=rtsp://admin:password@192.168.1.101:554/stream1 

# ── Worker Identity Configuration ─────────────────────────────
FACE_RECOGNITION_ENABLED=true
FACE_MODEL_BACKEND=ArcFace          # ArcFace | VGG-Face | Facenet512
FACE_DISTANCE_THRESHOLD=0.50        # lower = stricter match
FACE_BLUR_STORED_FRAMES=true        # GDPR compliance
WORKER_FRAMES_DIR=./data/worker_frames
RISK_SCORE_HIGH_THRESHOLD=15.0
RISK_SCORE_CRITICAL_THRESHOLD=25.0
HR_ALERT_COOLDOWN_HOURS=24          # only alert HR once per 24h per worker

# ── RBAC / API Key Management ──────────────────────────────────
RBAC_ENABLED=false               # set true in production
ADMIN_API_KEY=                   # generate: openssl rand -hex 32
MANAGER_API_KEY=                 # optional — manager role key
OPERATOR_API_KEY=                # optional — operator role key
VIEWER_API_KEY=                  # optional — read-only key

# ── Demo Mode ─────────────────────────────────────────────────
DEMO_MODE=false                  # set true for portfolio/trade show presentations

# ── Webhook Dispatcher ────────────────────────────────────────
WEBHOOK_TIMEOUT_SECONDS=10.0
WEBHOOK_MAX_RETRIES=3
WEBHOOK_SIGNING_SECRET=          # global HMAC secret (per-webhook secret overrides this)

# ── Export Configuration ──────────────────────────────────────
EXPORT_MAX_ROWS=50000            # maximum rows per export request

# ═══════════════════════════════════════════════════════════════
# ENTERPRISE SaaS ADDITIONS (v1.3.0)
# ═══════════════════════════════════════════════════════════════

# ── LLM Manager — Multi-provider fallback chain ────────────────
# Priority: Groq → OpenRouter → OpenAI → Ollama → Template
# Add GROQ_API_KEY to Render → LLM works FREE (14,400 req/day)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant

OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# Primary LLM for reports (llm_manager = use full fallback chain)
REPORT_LLM_PRIMARY=llm_manager

# ── Multi-tenant ──────────────────────────────────────────────
# X-Org-ID header value when no header is provided
DEFAULT_ORG_ID=default

# ── Billing (Razorpay India) ──────────────────────────────────
# Get keys at: https://dashboard.razorpay.com/app/keys
# Leave empty to run in demo mode (no actual payment)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay Plan IDs (create in Razorpay dashboard → Subscriptions → Plans)
RAZORPAY_PLAN_STARTER_MONTHLY=plan_xxxx
RAZORPAY_PLAN_STARTER_ANNUAL=plan_xxxx
RAZORPAY_PLAN_GROWTH_MONTHLY=plan_xxxx
RAZORPAY_PLAN_GROWTH_ANNUAL=plan_xxxx
RAZORPAY_PLAN_ENTERPRISE_MONTHLY=plan_xxxx
RAZORPAY_PLAN_ENTERPRISE_ANNUAL=plan_xxxx